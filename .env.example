# Copy to .env and fill in real values. Never commit .env.

# --- Database (required) ---
DATABASE_URL=mongodb+srv://user:password@cluster.example.mongodb.net/mydb
# DATABASE_URL=postgresql://user:password@host.example.com:5432/mydb
# DATABASE_URL=mysql://user:password@host.example.com:3306/mydb

# --- AWS S3 (required) ---
AWS_REGION=ap-south-1
# AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=my-app-database-backups

# Credentials: use ONE approach (omit all three on EC2/ECS/Lambda with IAM role)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=
# AWS_PROFILE=default

# --- Schedule ---
BACKUP_TIME=02:00
TIMEZONE=Asia/Karachi

# --- S3 key prefix (logical folder) ---
BASE_BACKUP_FOLDER=MyAppBackups

# --- After upload ---
KEEP_LOCAL_COPY=false

# --- Optional: S3-compatible (MinIO / LocalStack) ---
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

# --- Optional: storage class (must be valid for your bucket) ---
# S3_STORAGE_CLASS=STANDARD_IA

# --- Optional: retries after first failure (minimum 2 enforced in code) ---
# BACKUP_MAX_RETRIES=2
